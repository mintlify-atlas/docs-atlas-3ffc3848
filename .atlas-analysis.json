  "keyFeatures": [
    "Filesystem-based tool discovery",
    "Declarative .terse configuration files",
    "Pluggable database adapters (Postgres, MySQL, MongoDB, Redis)",
    "Embedded TypeScript scripting with sandboxed runtime",
    "Per-tool authentication with plugins",
    "MCP server over Streamable HTTP",
    "Build/compile/serve pipeline",
    "Hot reload with --watch flag",
    "OpenTelemetry observability",
    "In-memory caching with per-tool TTL"
  ],
  "publicApiSurface": [
    "hyperterse init - Scaffold new project",
    "hyperterse start - Run development server",
    "hyperterse start --watch - Run with hot reload",
    "hyperterse build - Compile to deployable artifact",
    "hyperterse serve - Run from compiled artifact",
    "hyperterse validate - Validate configuration",
    "hyperterse upgrade - Upgrade CLI version",
    "POST /mcp - MCP Streamable HTTP endpoint",
    "GET /heartbeat - Health check endpoint",
    "tools/list - List available MCP tools",
    "tools/call - Invoke MCP tool"
  ]
}
