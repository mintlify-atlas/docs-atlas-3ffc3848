{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Hyperterse",
  "description": "The declarative MCP framework for building performant tool servers with database adapters and embedded scripting",
  "theme": "mint",
  "font": {
    "family": "Inter"
  },
  "icons": {
    "library": "tabler"
  },
  "colors": {
    "primary": "#0D4A36",
    "light": "#86efac",
    "dark": "#0D4A36"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/hyperterse/hyperterse"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/hyperterse/hyperterse",
      "x": "https://x.com/hyperterse",
      "bluesky": "https://bsky.app/profile/hyperterse.com"
    }
  },
  "seo": {
    "metatags": {
      "og:title": "Hyperterse — Declarative MCP framework.",
      "twitter:title": "Hyperterse — Declarative MCP framework.",
      "og:description": "Production grade MCP tools that scale. Build declarative, deploy-ready AI tooling. No glue code.",
      "twitter:description": "Production grade MCP tools that scale. Build declarative, deploy-ready AI tooling. No glue code."
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/project-structure",
              "concepts/adapters",
              "concepts/tools",
              "concepts/scripts",
              "concepts/authentication"
            ]
          },
          {
            "group": "Runtime",
            "pages": [
              "runtime/mcp-transport",
              "runtime/execution-pipeline",
              "runtime/caching",
              "runtime/observability"
            ]
          },
          {
            "group": "Database Adapters",
            "pages": [
              "databases/postgresql",
              "databases/mysql",
              "databases/mongodb",
              "databases/redis"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/overview",
              "deployment/docker",
              "deployment/kubernetes",
              "deployment/bare-metal",
              "deployment/aws",
              "deployment/gcp",
              "deployment/azure",
              "deployment/railway",
              "deployment/digital-ocean",
              "deployment/cloudflare",
              "deployment/vercel"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/input-safety",
              "security/production-hardening"
            ]
          },
          {
            "group": "Migration",
            "pages": ["migration/v1-to-v2"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "CLI Commands",
            "pages": ["reference/cli"]
          },
          {
            "group": "Configuration",
            "pages": [
              "reference/root-config",
              "reference/adapter-config",
              "reference/tool-config",
              "reference/environment-variables",
              "reference/configuration-schemas"
            ]
          }
        ]
      }
    ]
  }
}
